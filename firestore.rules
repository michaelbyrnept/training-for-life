rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.uid == "wKbgHNtTMtS01BQ4ddfAwTQaIgA3";
    }
    match /assessmentResults/{doc} {
      allow read: if request.auth != null && resource.data.email == request.auth.token.email;
      allow create: if true;
    }
    match /exercises/{doc} {
      allow read: if true;
      allow write: if request.auth.uid == "wKbgHNtTMtS01BQ4ddfAwTQaIgA3";
    }
    match /workouts/{doc} {
      allow read: if true;
      allow write: if request.auth.uid == "wKbgHNtTMtS01BQ4ddfAwTQaIgA3";
    }
    match /programmes/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "wKbgHNtTMtS01BQ4ddfAwTQaIgA3";
      match /weeks/{weekId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == "wKbgHNtTMtS01BQ4ddfAwTQaIgA3";
      }
    }
    match /workoutLogs/{doc} {
      allow read, write: if request.auth != null;
    }
    match /nutritionLogs/{logId} {
      allow read, write: if request.auth != null;
    }
    match /weightLogs/{doc} {
      allow read, write: if request.auth != null;
    }
    match /clientNotes/{doc} {
      allow read, write: if request.auth.uid == "wKbgHNtTMtS01BQ4ddfAwTQaIgA3";
    }
    match /metrics/{doc} {
      allow read: if true;
      allow write: if request.auth.uid == "wKbgHNtTMtS01BQ4ddfAwTQaIgA3";
    }
    match /habitLogs/{doc} {
      allow read, write: if request.auth != null;
    }
    match /classes/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == "wKbgHNtTMtS01BQ4ddfAwTQaIgA3";
    }
    match /classLogs/{doc} {
      allow read, write: if request.auth != null;
    }
    match /checkIns/{doc} {
      allow read, write: if request.auth != null;
    }
    match /progressPhotos/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}