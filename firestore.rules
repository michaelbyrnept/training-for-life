rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ──────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.uid == "wKbgHNtTMtS01BQ4ddfAwTQaIgA3";
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // ─── USERS ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read, write: if isAdmin();

      // User-created custom workouts (Premium Workout Builder)
      match /workouts/{workoutId} {
        allow read, write: if isOwner(userId);
        allow read, write: if isAdmin();
      }

      // Personal bests — owner can read, Cloud Functions write via Admin SDK
      // Client writes allowed so UI can optimistically update; CF is authoritative
      match /personalBests/{exerciseId} {
        allow read, write: if isOwner(userId);
        allow read: if isAdmin();
      }

      // User-created custom programmes (Premium)
      match /userProgrammes/{programmeId} {
        allow read, write: if isOwner(userId);
        allow read: if isAdmin();
      }

      // Third-party integration tokens (Strava etc.) — owner only, never admin
      match /integrations/{integrationId} {
        allow read, write: if isOwner(userId);
      }

      // Strava activity cache — owner read, Cloud Functions write via Admin SDK
      match /stravaActivities/{activityId} {
        allow read: if isOwner(userId);
        allow write: if false; // written by Cloud Function only
      }
    }
    // ─── EXERCISE LIBRARY ──────────────────────────────────────────────────────
    match /assessmentResults/{doc} {
      allow read: if isAuthenticated() && (resource.data.email == request.auth.token.email || isAdmin());
      allow create: if true;
    }
    match /exercises/{doc} {
      allow read: if true;
      allow write: if isAdmin();
      // Exercise media version history — admin-write, public-read
      match /mediaHistory/{versionId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ─── COACH-CREATED PROGRAMMES & WORKOUTS ───────────────────────────────────
    // Note: /workouts here is coach-published programme workouts, NOT user custom workouts.
    // User custom workouts live at /users/{userId}/workouts (see above).
    match /workouts/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /programmes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
      match /weeks/{weekId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ─── USER ACTIVITY LOGS ────────────────────────────────────────────────────
    match /workoutLogs/{doc} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
    }
    match /nutritionLogs/{logId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
    }
    match /weightLogs/{doc} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
    }
    match /habitLogs/{doc} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
    }
    match /classLogs/{doc} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
    }
    match /checkIns/{doc} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
    }
    match /progressPhotos/{doc} {
      allow read, write: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    // ─── GROUPS ────────────────────────────────────────────────────────────────
    match /groups/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── ADMIN-ONLY CONTENT ────────────────────────────────────────────────────
    match /clientNotes/{doc} {
      allow read, write: if isAdmin();
    }
    match /metrics/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /classes/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /meals/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /customMilestones/{doc} {
      allow read, write: if isAdmin();
    }

    // ─── MEAL PLANS ────────────────────────────────────────────────────────────
    match /mealPlans/{doc} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
    }

    // ─── EXERCISE REQUESTS ─────────────────────────────────────────────────────────
    // Members submit exercise requests when search finds nothing.
    match /exerciseRequests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // ─── LEAD / INTAKE ─────────────────────────────────────────────────────────
    match /consultations/{doc} {
      allow read, write: if isAdmin();
      allow create: if true;
    }
    match /waitlist/{doc} {
      allow read, write: if isAdmin();
      allow create: if true;
    }

    // ─── SESSIONS & WALLET ─────────────────────────────────────────────────────
    match /sessions/{doc} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.clientId || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    match /sessionBundles/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /bundlePurchases/{doc} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.clientId || isAdmin());
      allow create: if isAdmin();
    }
    match /walletTransactions/{doc} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.clientId || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ─── MEANINGFUL MOMENTS ENGINE ─────────────────────────────────────────────
    match /milestones/{doc} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.clientId || isAdmin());
      allow update: if isAdmin();
      allow create: if isAdmin();
      allow dele